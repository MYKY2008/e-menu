# GastroLink QR — Environment Configuration
# Skopírujte tento súbor do .env a vyplňte hodnoty.
# Súbor .env NIKDY nevkladajte do version control (git)!

# ── Aplikácia ────────────────────────────────────────────────
# Absolútna URL vašej inštalácie (bez trailing slash)
APP_URL=https://gastrolink.sk

# ── SMTP (odosielanie e-mailov) ───────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_USER=noreply@example.com
SMTP_PASS=your_smtp_password

# ── Odosielateľ ───────────────────────────────────────────────
MAIL_FROM=noreply@gastrolink.sk
MAIL_FROM_NAME=GastroLink QR

# ── Stripe ────────────────────────────────────────────────────
# Tajný kľúč z Stripe Dashboard (Developers → API keys)
STRIPE_SECRET_KEY=sk_live_...
# Webhook signing secret (Developers → Webhooks → Signing secret)
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs z Stripe Dashboard (Products → Prices)
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ULTRA=price_...
STRIPE_PRICE_CUSTOM=price_...
